# AGENT_ARENA_TASKS_PATH=./data/tasks.csv
# AGENT_ARENA_STORAGE_DIR=./storage
AGENT_ARENA_SEARCH_ENGINE=native
AGENT_ARENA_SEARCH_MAX_RESULTS=5
AGENT_ARENA_SEARCH_MAX_TOTAL_RESULTS=10
