# Ignore everything by default, then allowlist the final Agent Arena app files.
*

# Project metadata / setup
!.gitignore
!.env.example
!README.md
!requirements.txt

# Entrypoints
!run_benchmark.py
!audit_ground_truth.py
!seed_ground_truth_from_audit.py
!export_launch_snapshot.py

# App source
!backend/
!backend/*.py
!frontend/
!frontend/index.html

# Final task bank
!data/
!data/tasks.csv
!data/excluded_tasks.json

# Always keep local secrets, generated artifacts, and scratch docs private.
.env
.env.*
!.env.example
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.DS_Store
node_modules/
dist/
storage/
!storage/
storage/*
!storage/runs.jsonl
!storage/ground_truth.jsonl
!storage/v1_ground_truth_audit.csv
docs/
