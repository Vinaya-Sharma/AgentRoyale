# Ignore everything by default, then allowlist public Agent Royale files.
*

# Project metadata / setup
!.gitignore
!.env.example
!README.md
!requirements.txt
!pyproject.toml
!LICENSE
!CONTRIBUTING.md
!CHANGELOG.md
!TASK_PACK_IDEAS.md
!ROADMAP.md
!.github/
!.github/ISSUE_TEMPLATE/
!.github/ISSUE_TEMPLATE/*.md
!.github/workflows/
!.github/workflows/*.yml
!agent_royale/
!agent_royale/*.py
!task-packs/
!task-packs/**/
!task-packs/**/*.yaml
!task-packs/**/*.json
!task-packs/**/*.md
!examples/
!examples/*.py
!examples/**/
!examples/**/*.py
!examples/**/*.md
!examples/**/requirements.txt
!docs/
!docs/*.md
!docs/**/
!docs/**/*.md
!docs/assets/
!docs/assets/*.png
!docs/assets/**/
!docs/assets/**/*.png

# Entrypoints
!run_benchmark.py
!audit_ground_truth.py
!seed_ground_truth_from_audit.py
!export_launch_snapshot.py

# App source
!backend/
!backend/*.py
!frontend/
!frontend/index.html
!frontend/assets/
!frontend/assets/**

# Final task bank
!data/
!data/tasks.csv
!data/excluded_tasks.json

# Always keep local secrets, generated artifacts, and scratch docs private.
.env
.env.*
!.env.example
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.DS_Store
node_modules/
dist/
storage/
!storage/
storage/*
!storage/runs.jsonl
!storage/ground_truth.jsonl
!storage/v1_ground_truth_audit.csv
reports/*
!reports/
!reports/dev-web-retrieval-v1/
!reports/dev-web-retrieval-v1/*.html
